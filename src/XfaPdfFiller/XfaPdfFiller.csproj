<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net6.0;net8.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <RootNamespace>XfaPdfFiller</RootNamespace>
    <AssemblyName>XfaPdfFiller</AssemblyName>
    <Description>Lightweight library to fill XFA forms in PDF documents without iTextSharp dependency</Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="XfaPdfFiller.Tests" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <PackageReference Include="System.Memory" Version="4.5.5" />
  </ItemGroup>

</Project>
